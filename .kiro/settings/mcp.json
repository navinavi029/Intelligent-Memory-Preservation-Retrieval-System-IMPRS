{
  "mcpServers": {
    "playwright-browser": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "browser_navigate",
        "browser_click",
        "browser_press_key",
        "browser_type",
        "browser_take_screenshot",
        "browser_snapshot",
        "browser_close",
        "browser_file_upload",
        "browser_run_code",
        "browser_wait_for"
      ]
    },
    "puppeteer-browser": {
      "command": "uvx",
      "args": [
        "mcp-server-puppeteer"
      ],
      "env": {},
      "disabled": true,
      "autoApprove": []
    },
    "postgres": {
      "command": "uvx",
      "args": [
        "postgres-mcp-server",
        "postgresql://postgres:Obelisk_029@localhost:5432/pdf_rag_db"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "query",
        "list_tables",
        "describe_table"
      ]
    }
  }
}